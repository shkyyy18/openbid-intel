{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shkyyy18.github.io/openbid-intel/schemas/profile.schema.json",
  "title": "OpenBid Intel profile",
  "type": "object",
  "required": [
    "business_lines"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "buyer_terms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "procurement_terms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "negative_terms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "focus_regions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "min_budget_cny": {
      "type": "number",
      "minimum": 0
    },
    "stage_weights": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "sales_profile": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "all_business_lines": {
          "type": "boolean"
        },
        "focus_regions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "minimum_followup_budget_cny": {
          "type": "number",
          "minimum": 0
        },
        "priority_accounts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "aliases"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "aliases": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "weight": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "business_lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "strong_terms",
          "related_terms"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "base_score": {
            "type": "integer",
            "minimum": 0
          },
          "strong_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "related_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
