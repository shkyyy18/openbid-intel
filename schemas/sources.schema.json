{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shkyyy18.github.io/openbid-intel/schemas/sources.schema.json",
  "title": "OpenBid Intel source configuration",
  "type": "object",
  "required": [
    "sources"
  ],
  "properties": {
    "request_interval_seconds": {
      "type": "number",
      "minimum": 0
    },
    "max_detail_fetches": {
      "type": "integer",
      "minimum": 0
    },
    "max_pages": {
      "type": "integer",
      "minimum": 1
    },
    "history_days": {
      "type": "integer",
      "minimum": 0
    },
    "priority_detail_terms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "url"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "stage": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "region": {
            "type": "string"
          },
          "buyer": {
            "type": "string"
          },
          "max_pages": {
            "type": "integer",
            "minimum": 1
          },
          "history_days": {
            "type": "integer",
            "minimum": 0
          },
          "max_items": {
            "type": "integer",
            "minimum": 1
          },
          "note": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
